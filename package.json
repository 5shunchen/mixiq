{
  "name": "@5shunchen/mixiq",
  "version": "1.0.0",
  "description": "MixIQ - AI-native Agent Development & Operations MCP Server for Claude Code",
  "main": "dist/server.js",
  "bin": {
    "mixiq": "./dist/server.js"
  },
  "mcp": {
    "name": "mixiq",
    "version": "1.0.0",
    "description": "AI-native agent development and operations platform with 37 MCP tools",
    "tools": 37,
    "protocols": ["stdio"]
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "ts-node src/server.ts",
    "test": "jest",
    "test:unit": "jest tests/unit/",
    "test:integration": "jest tests/integration/",
    "test:coverage": "jest --coverage",
    "install:mcp": "node scripts/install-mcp.js",
    "install:cli": "npm link",
    "postinstall": "npm run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/5shunchen/mixiq.git"
  },
  "keywords": [
    "mcp",
    "claude",
    "claude-code",
    "ai",
    "agent",
    "devops",
    "ssh",
    "git",
    "automation",
    "workflow",
    "orchestration"
  ],
  "author": "MixIQ Team",
  "license": "MIT",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/5shunchen/mixiq/issues"
  },
  "homepage": "https://github.com/5shunchen/mixiq#readme",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "better-sqlite3": "^11.8.1",
    "node-ssh": "^13.2.0",
    "simple-git": "^3.36.0",
    "uuid": "^11.1.0",
    "winston": "^3.17.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.8.0",
    "@types/uuid": "^10.0.0",
    "jest": "^30.4.2",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  },
  "files": [
    "dist/**/*",
    "scripts/**/*",
    "config/**/*",
    "README.md"
  ]
}
